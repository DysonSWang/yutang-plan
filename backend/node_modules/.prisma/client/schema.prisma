// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========== 关系阶段常量（String存储，应用层校验）==========
// 有效值：EXPLORATION | FLIRTING | ADVANCEMENT | CONFIRMATION | STABLE
// EXPLORATION = 探索期：从认识到建立基础连接
// FLIRTING = 暧昧期：有明显兴趣信号，但未正式确认关系
// ADVANCEMENT = 推进期：主动升级关系，有明确的追求动作
// CONFIRMATION = 确认期：双方有意愿，需要正式表白或确认
// STABLE = 稳定期：关系确立，进入长期维护

// ========== 用户系统 ==========
model User {
  id       String  @id @default(uuid())
  username String  @unique
  password String
  nickname String?
  avatar   String?
  phone    String?
  role     String  @default("client") // client, operator, admin

  // ===== 基础信息 =====
  age        Int? // 年龄
  occupation String? // 职业
  education  String? // 学历
  income     String? // 收入水平
  height     Int? // 身高(cm)
  residence  String? // 所在地
  hometown   String? // 籍贯

  // ===== 外貌资源 =====
  appearance    String? // 外貌描述
  dressingStyle String? // 穿着风格
  photos        String? // JSON array - 照片

  // ===== 家庭背景 =====
  familyBackground String? // 家庭背景：农村/城市/经商/公务员
  familyStructure  String? // 家庭结构：双亲/单亲/离异
  familyAtmosphere String? // 家庭氛围
  familyBurden     String? // 养老负担
  familyMembers    String? // 家庭成员说明

  // ===== 性格画像（AI提炼）=====
  personality        String? // MBTI/性格标签
  emotionalStable    Int? // 情绪稳定性 1-10
  eqLevel            Int? // 情商水平 1-10
  communicationStyle String? // 沟通风格：直接/含蓄/话多/话少
  socialStyle        String? // 社交风格：主动/被动/社交达人

  // ===== 情感状态 =====
  relationshipAttitude    String? // 婚恋态度：认真/随便/急切
  pastRelationshipSummary String? // 情史摘要
  marriageHistory         String? // 婚史：未婚/离异/丧偶
  emotionalWounds         String? // 情伤记录
  exPartnerTaboos         String? // 介意的前任类型

  // ===== 情感目标（四位专家新增）=====
  emotionalGoal         String? // 感情诉求：认真/随便/家里催/空虚
  relationshipGoal      String? // 关系目标：短期/长期/不确定
  commitmentWillingness Int? // 承诺意愿 1-10
  emotionalMaturity     String? // 感情认知水平：幼稚/一般/成熟

  // ===== 学习能力 =====
  learningAbility  String? // 学习能力：强/中/弱
  coachCooperation String? // 配合度：配合/一般/抵触
  feedbackQuality  String? // 反馈质量：详细/简单/无反馈

  // ===== 价值画像（Mo哥新增）=====
  strengths  String? // 核心卖点：有钱/幽默/真诚/帅气
  weaknesses String? // 价值短板：长相/情商/聊天/money

  // ===== 客户类型（Mo哥新增）=====
  clientType String? // 客户类型：执行型/质疑型/自主型

  // ===== 认知评估（旭哥新增）=====
  selfValuePerception String? // 自我价值认知：认为自己哪方面最强
  cognitiveAccuracy   String? // 认知准确度：准确/高估/低估

  // ===== 资源投入 =====
  assetsLevel    String? // 资产级别
  budgetRange    String? // 预算范围
  timeInvestment String? // 时间投入意愿
  serviceStage   String? // 服务阶段：背调/建池/约会/锁定/维护

  // ===== 客户上下文记忆 =====
  signals             String? // JSON数组: [{"date":"","type":"","event":""}]
  pendingActions      String? // JSON数组
  observations        String? // JSON数组
  conversationSummary String? // 与操盘手沟通摘要

  // ===== 匹配相关 =====
  matchPreferences String? // 理想型偏好
  dealbreakers     String? // 绝对雷区

  // ===== 社交主页展示面 =====
  profilePhotos      String? // JSON array - 主页照片列表
  profileBio         String? // 主页简介/个人签名
  preferredPlatforms String? // 常用平台：微信/探探/Soul等

  // ===== 代聊风格（凯哥新增）=====
  openingTemplates String? // JSON array - 打招呼模板话术
  petPhrases       String? // JSON array - 客户口头禅/习惯用语
  interactionStyle String? // 互动风格：主动型/调理型/细腻型
  chatTaboos       String? // JSON array - 代聊禁区：哪些话不能说
  humorStyle       String? // 幽默风格：冷幽默/自嘲/调侃/正经

  // ===== 阶段进度（凯哥新增）=====
  currentStage  String? // 当前阶段：陌生/朋友/暧昧/亲密
  stageProgress Int? // 阶段进度 0-100%
  lastMilestone String? // 最近里程碑事件

  // ===== 抗压与节奏（凯哥+旭哥新增）=====
  selfEsteemLevel      String? // 自尊水平：高/中/低
  antiFrustrationLevel Int? // 抗压能力 1-10
  pacePreference       String? // 节奏偏好：快节奏/稳健型/慢热型

  // ===== 投入意愿（旭哥新增）=====
  investmentWillingness String? // 投入意愿：时间/金钱/精力维度

  // ===== 舒适区（旭哥新增）=====
  comfortZone String? // 舒适区：习惯哪种类型的女生

  // ===== 【评审团新增 P0】依恋类型 & 量化EQ维度 =====
  attachmentStyle  String? // 依恋类型：焦虑型/回避型/安全型
  empathy          Int? // 同理心 1-10
  communication    Int? // 沟通能力 1-10
  conflictRes      Int? // 冲突解决能力 1-10
  intimacyBoundary String? // 物理亲密边界描述

  // ===== 【评审团新增 P0】约会雷区 =====
  dateTaboos String? // 约会雷区：哪些情况绝对不能做

  // ===== 【评审团新增 P1】恋爱风格 & 五种爱的语言 =====
  loveStyle     String? // 恋爱风格：真诚型/陪伴型/言语型/身体型/浪漫型
  loveLanguage1 String? // 第一爱的语言
  loveLanguage2 String? // 第二爱的语言
  loveLanguage3 String? // 第三爱的语言
  loveLanguage4 String? // 第四爱的语言
  loveLanguage5 String? // 第五爱的语言

  // ===== 【评审团新增 P1】约会金钱观念 =====
  moneyDatingPattern String? // 买单观念：AA/请客/轮流/看情况

  // ===== 【评审团新增 P1】前任关系模式分析 =====
  pastRelationshipPattern String? // 前任模式分析：重复了什么样的关系角色

  // ===== 【评审团新增 P1】外表吸引力自评与需求 =====
  appearanceSelfAssessment  String? // 外表自评：客户认为自己颜值区间
  appearanceSelfRequirement String? // 对女生颜值的要求描述
  appearanceMinAcceptable   String? // 能接受女生最差颜值下限

  // ===== 【评审团新增】量化版本（替代String字段，逐步迁移）=====
  emotionalMaturityLevel Int? // 感情认知水平 1-10（原 emotionalMaturity 文字版保留）
  coachCooperationLevel  Int? // 配合度 1-10（原 coachCooperation 文字版保留）

  // ===== 【评审团新增】客户AI战略分析（对标女生 bestApproach/recommendedTopics 等）=====
  clientBestApproach      String? // 最佳追求策略：幽默/真诚/霸道/温柔/调理型
  clientRecommendedTopics String? // 推荐话题
  clientUpgradeConditions String? // 升级条件
  clientRiskFactors       String? // 风险因素
  clientStrategicNotes    String? // 战略备注

  // ===== 信任度/亲密度（类比女生）=====
  trustLevel      Int   @default(1) // 1-5信任度
  interactionHeat Float @default(5.0) // 1.0~10.0 互动热度

  // ===== 语音克隆素材 =====
  voiceSamples String? // JSON array - 语音样本URL列表，用于音色克隆

  // ===== 元数据 =====
  balance          Float     @default(0)
  girlQuota        Int       @default(1) // 女生额度上限，新建客户默认1（体验版）
  notes            String? // 备注
  source           String? // 客户来源
  serviceStartDate DateTime? // 服务开始日期

  // ===== 关系 =====
  clientGirls      Girl[]             @relation("ClientGirls")
  events           Event[]
  operatorSessions ChatSession[]      @relation("OperatorSessions")
  dates            Date[]
  payments         Payment[]
  progress         ServiceProgress[]
  learnings        ClientLearning[]
  alerts           Alert[]
  memberships      Membership[]
  invitations      Invitation[]       @relation("Inviter")
  invitationsUsed  Invitation[]       @relation("Invitee")
  renewalCoupons   RenewalCoupon[]
  pointsLedger     PointsLedger[]
  learningProgress LearningProgress[]
  datingPlans      DatingPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ========== 女生资源池 ==========
model Girl {
  // ===== 基础信息 =====
  id         String  @id @default(uuid())
  name       String // 姓名/昵称
  age        Int? // 年龄
  occupation String? // 职业
  education  String? // 学历
  major      String? // 专业
  hometown   String? // 籍贯
  residence  String? // 现居城市
  workplace  String? // 工作地点

  // ===== 外貌特征 =====
  appearance   String? // 外貌描述（穿着风格）
  height       Int? // 身高(cm)
  bodyType     String? // 体型：偏瘦/标准/微胖/偏胖
  photos       String? // JSON array - 照片
  homepageUrl  String? // 主页链接（个人网站/社交主页）
  videos       String? // JSON array - 视频链接
  styleTags    String? // 风格标签：文艺/运动/精致/朴素
  momentPhotos String? // JSON array - 朋友圈截图

  // ===== 家庭背景 =====
  familyBackground String? // 农村/城市/经商/公务员
  familyAtmosphere String? // 和睦/离异/单亲
  familyBurden     String? // 养老负担
  familyComments   String? // 家庭备注

  // ===== 生活状态 =====
  workSchedule    String? // 朝九晚五/自由职业/经常加班
  socialActivity  String? // 社交活跃度：高/中/低
  financialHabits String? // 月光/务实/超前

  // ===== 兴趣爱好 =====
  interests        String? // 兴趣爱好
  // 饮食偏好/禁忌存储为逗号分隔字符串，标准化标签见前端 DIET_PREFERENCES/DIET_RESTRICTIONS
  dietPreferences  String? // 饮食偏好（多选，如：清淡,火锅,日料）
  dietRestrictions String? // 饮食禁忌/过敏（多选，如：不吃辣,海鲜过敏,酒精过敏）
  hobbiesDetail    String? // 兴趣详情

  // ===== 情感状态（Mo哥+童锦程）=====
  relationshipAttitude    String? // 婚恋态度：认真/随便/不清楚
  pastRelationshipSummary String? // 情史摘要
  emotionalWounds         String? // 情伤记录：被渣/家暴/丧偶/其他
  attachmentStyle         String? // 依恋类型：焦虑/回避/安全
  dealbreakers            String? // 绝对雷区

  // ===== 字母圈属性（操盘手专用）=====
  isKinkOriented Boolean @default(false) // 是否接触字母圈
  kinkIdentity   String? // S/M/Switch/观望/探索者
  kinkBoundaries String? // 硬边界/软边界/雷区
  kinkInterests  String? // 兴趣标签
  kinkExperience String? // 新手/有经验/资深
  kinkNotes      String? // 安全词/特殊需求

  // ===== 内在画像（AI提炼，持续更新）=====
  personality        String? // MBTI/性格标签
  values_            String? // 价值观：事业型/家庭型/自由型
  communicationStyle String? // 沟通风格：直接/含蓄/话多/话少
  emotionalTriggers  String? // 情绪触发点
  talkingTopics      String? // 喜欢的话题
  thingsToAvoid      String? // 禁忌话题

  // ===== 关系状态 =====
  stage                  String? // 当前阶段：陌生/搭讪/聊天/暧昧/约会/长期
  status                 String    @default("available") // available, chatting, dating, locked, long_term
  intimacyLevel          Int       @default(1) // 1-5亲密度
  intimacyLevelUpdatedAt DateTime? // 亲密度最后更新时间（AI提炼时更新）
  tensionScore           Float     @default(5.0) // 1.0~10.0关系热度
  tensionScoreUpdatedAt  DateTime? // 热度最后更新时间（AI提炼时更新）
  lastContact            DateTime? // 最后联系时间
  responsePattern        String? // 回复规律：秒回/慢/已读不回

  // ===== 关系阶段（5阶段枚举，M007 S01新增）=====
  relationshipStage          String? // EXPLORATION|FLIRTING|ADVANCEMENT|CONFIRMATION|STABLE
  relationshipStageUpdatedAt DateTime? // 关系阶段最后更新时间

  // ===== 上下文记忆（持续更新）=====
  signals             String? // JSON数组
  pendingActions      String? // JSON数组
  observations        String? // JSON数组
  conversationSummary String? // 压缩后的对话摘要

  // ===== AI战略分析 =====
  bestApproach      String? // 最佳策略：幽默/真诚/霸道/温柔
  recommendedTopics String? // 推荐话题
  upgradeConditions String? // 升级条件
  estimatedTimeline String? // 预计时间线
  riskFactors       String? // 风险因素
  strategicNotes    String? // 战略备注

  // ===== AI画像（谙世eq-profile维度）=====
  empathy       Int?
  selfAwareness Int?
  communication Int?
  relationship  Int?
  conflictRes   Int?

  // ===== 谙世角色关联 ======
  chatPartnerId String? // 对应谙世角色库的ID

  // ===== 匹配相关 =====
  matchScore      Int?
  matchScoreBasis String? // 匹配分计算依据（算法说明或参考因素）
  matePreferences String? // 择偶偏好：年龄范围/学历/地域/职业/收入/其他要求

  // ===== 元数据 =====
  sourcePlatform String? // 平台来源
  sourceUrl      String? // 主页链接
  notes          String? // 备注

  // ===== 关系 =====
  clientId String
  client   User   @relation("ClientGirls", fields: [clientId], references: [id])

  chatLogs        ChatLog[]
  chatScreenshots ChatScreenshot[]
  dates           Date[]
  events          Event[]
  stageHistory    RelationshipStageHistory[]
  alerts          Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("girls")
}

// ========== 关系阶段历史（M007 S01新增）==========
model RelationshipStageHistory {
  id     String @id @default(uuid())
  girlId String
  girl   Girl   @relation(fields: [girlId], references: [id])

  // 阶段变更
  fromStage String? // null 表示初始设置
  toStage   String // EXPLORATION|FLIRTING|ADVANCEMENT|CONFIRMATION|STABLE

  // 变更原因
  reason String? // 操盘手填的或AI评估的原因
  source String  @default("manual") // 'manual' | 'ai_evaluate' | 'event_trigger'

  // 操作人
  changedBy String // operatorId

  createdAt DateTime @default(now())

  @@index([girlId])
  @@map("relationship_stage_history")
}

// ========== 操盘手↔客户 私密聊天 ==========
model ChatSession {
  id            String    @id @default(uuid())
  operatorId    String
  operator      User      @relation("OperatorSessions", fields: [operatorId], references: [id])
  clientId      String
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int       @default(0)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operatorId, clientId])
  @@map("chat_sessions")
}

model Message {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])

  senderRole String
  senderId   String

  content  String?
  type     String  @default("text")
  mediaUrl String?
  duration Int?

  isBurnAfterRead  Boolean   @default(false)
  burnAfterSeconds Int? // 自动销毁倒计时秒数（阅后即焚时）
  burnedAt         DateTime?
  recalledAt       DateTime?

  isFlashImage  Boolean   @default(false) // 闪图：查阅后5秒自动销毁
  flashBurnedAt DateTime?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("messages")
}

// ========== 聊天截图记录 ==========
model ChatScreenshot {
  id     String @id @default(uuid())
  girlId String
  girl   Girl   @relation(fields: [girlId], references: [id])

  clientId   String
  operatorId String

  imageUrl String
  chatText String? // 从截图识别的原始对话文本
  notes    String?
  platform String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_screenshots")
}

// ========== 代聊记录 ==========
model ChatLog {
  id     String @id @default(uuid())
  girlId String
  girl   Girl   @relation(fields: [girlId], references: [id])

  clientId   String
  operatorId String

  receiverName String
  content      String
  type         String @default("text") // text | moment_text | moment_image

  aiAnalysis    String?
  aiSuggestions String?
  aiAdopted     Boolean @default(false)

  // 朋友圈相关（当 type 为 moment_* 时）
  momentImageUrl String?
  momentText     String?

  isVisibleToClient Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("chat_logs")
}

// ========== 约会管理 ==========
model Date {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  girlId String
  girl   Girl   @relation(fields: [girlId], references: [id])

  // 基础
  dateTime DateTime
  title    String? // 约会简称，如"第一次见面"
  location String?

  // 状态：pending_plan（待策划）/ planned（已策划）/ completed（已完成）/ cancelled（取消）
  status     String  @default("pending_plan")
  notes      String?
  nextAction String?

  // ========== 约会前检查清单 ==========
  preDateChecklist String? // JSON: [{ category, items: [{ id, label, checked }] }]

  // ========== 约会条件（策划输入）==========
  conditions String? // JSON: { budget, dateStyle, interests, restrictions, specialRequirements }

  // ========== AI 生成的约会方案 ==========
  aiPlan     String? // JSON: { overview, venue, schedule, talkingPoints, precautions, outfit, budgetTips }
  planStatus String? // pending / generating / generated / rejected

  // ========== 方案确认流程 ==========
  // planDiscussion: 操盘手与AI的讨论记录 [{ role: 'operator'|'ai', content, timestamp }]
  planDiscussion  String?
  // clientFeedback: 客户对方案的调整建议 [{ adjustment, reason, submittedAt }]
  clientFeedback  String?
  // clientConfirmed: 客户是否已确认方案
  clientConfirmed Boolean   @default(false)
  // pushToClientAt: 方案推送给客户的时间
  pushToClientAt  DateTime?
  // confirmedAt: 客户确认时间
  confirmedAt     DateTime?

  // ========== 约会后记录 ===========
  expenseRecord     String? // JSON: [{ item, amount }]
  totalExpense      Float? // 总花费
  duration          String? // 时长，如"2小时"
  postDateInterview String? // JSON: 约会后结构化访谈数据

  // ========== 约会评价 ===========
  rating          Int? // 1-5 星
  positiveSignals String? // JSON: [{ signal, note }]
  negativeSignals String? // JSON: [{ signal, note }]
  followUpActions String? // JSON: [{ action, priority, deadline }]
  postNotes       String? // 约会后总结

  // ========== 女生状态同步 ===========
  // 约会完成后可更新女生阶段
  girlStageAfter String? // 约会后女生阶段

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dates")
}

// ========== 服务进度 ==========
model ServiceProgress {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  stage     Int
  stageName String
  status    String @default("in_progress")

  amountPaid  Float?
  paidAt      DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_progress")
}

// ========== 阶段付款 ==========
model Payment {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  stage  Int
  amount Float
  status String @default("pending")

  paidAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("payments")
}

// ========== 日历事件 ==========
// 统一管理：约会 + AI教练行动项 + 手动添加事件
model Event {
  id       String  @id @default(uuid())
  clientId String
  client   User    @relation(fields: [clientId], references: [id])
  girlId   String?
  girl     Girl?   @relation(fields: [girlId], references: [id])

  // 基础字段
  title     String // 事件标题
  content   String? // 事件内容/描述
  eventTime DateTime // 事件时间
  endTime   DateTime? // 结束时间（可选）

  // 类型：date(约会) | action(AI行动项) | manual(手动添加)
  type String @default("manual")

  // 状态
  status String @default("pending") // pending | completed | cancelled

  // AI教练来源（action类型时）
  source    String? // 'ai_coach' | 'chat_selection' | 'manual'
  aiContext String? // AI响应原文片段（action类型时保存，方便回溯）

  // 来源ID（用于关联）
  dateId    String? // 关联的约会ID（type=date时）
  chatLogId String? // 关联的聊天记录ID（选中文本添加时）

  // 颜色标签（前端用）
  color String? // hex颜色，不填则按类型默认

  // 元数据
  notes    String?
  metadata String? // JSON: { channel, contact, ... }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([girlId])
  @@index([eventTime])
  @@index([type])
  @@map("events")
}

// ========== 操作日志 ==========
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ========== 主动预警（M007 S02新增）==========
model Alert {
  id String @id @default(uuid())

  // 归属：哪个操盘手创建的（用于查询）
  operatorId String

  // 关联客户和女生
  clientId String?
  girlId   String? // 可选，某些预警是系统级的

  // 预警分类
  alertType     String // 'proactive' | 'signal' | 'action'
  // 严重度
  severity      String // 'P0' | 'P1' | 'P2'
  // 预警标题和内容
  title         String
  message       String
  // 触发原因（用于展示和调试）
  triggerReason String?

  // 状态
  status String @default("active") // 'active' | 'acknowledged' | 'dismissed' | 'resolved'

  // 过期时间（可选，过期后自动不显示）
  expiresAt DateTime?

  // 元数据（JSON：保留触发条件的原始数据）
  metadata String?

  // 关联
  operator User  @relation(fields: [operatorId], references: [id])
  girl     Girl? @relation(fields: [girlId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId])
  @@index([clientId])
  @@index([girlId])
  @@index([status])
  @@index([severity])
  @@index([operatorId, status])
  @@map("alerts")
}

// ========== 通知 ==========
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  content   String
  isRead    Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ========== 客户经验库 ==========
model ClientLearning {
  id       String  @id @default(uuid())
  clientId String
  client   User    @relation(fields: [clientId], references: [id])
  girlId   String?

  type    String
  scene   String
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_learnings")
}

// ========== 待确认档案更新队列 ==========
model PendingProfileUpdate {
  id         String @id @default(uuid())
  targetType String // 'girl' | 'client'
  targetId   String // girlId or clientId
  source     String // 'chat_analyze' | 'chat_optimize' | 'notes' | 'screenshot'

  // 操盘手/操作人
  operatorId String

  // 档案上下文（用于展示 diff）
  profileContext String? // JSON: { name, stage, tensionScore, ... }

  // 分析结果
  analysisData String // JSON: { profileUpdates, newSignals, tensionAdjustment, stageChange, observations, pendingActions, ... }

  // 采纳的回复（如果有，来源是 chat_analyze 时）
  adoptedReply String? // 操盘手最终采纳的回复内容
  replyStyle   String? // 风格标签

  // 状态：pending / approved / rejected
  status String @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId, status])
  @@index([operatorId, status])
  @@map("pending_profile_updates")
}

// ========== 对话记忆 ==========
model ConversationMemory {
  id       String  @id @default(uuid())
  clientId String
  girlId   String?
  coachId  String

  messages     String
  summary      String?
  signals      String?
  stageChanged Boolean @default(false)

  // ---- CC风格压缩 ----
  compactionCount     Int     @default(0) // 累计压缩次数
  removedMessageCount Int     @default(0) // 累计移除消息数
  compactionChain     String? // JSON: [{seq, summary, timestamp}] 递归压缩链
  tokenCount          Int     @default(0) // 累计消息token数（估算）

  // ---- 硬约束（压缩时必须保留）----
  hardConstraints String? // JSON: { taboos, emotionalTriggers, thingsToAvoid, ... } 女生禁忌等信息

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks CoachFeedback[]

  @@map("conversation_memories")
}

// ========== GirlSummary 缓存 ==========
model GirlSummaryCache {
  id       String @id @default(uuid())
  cacheKey String @unique // daily:{clientId}:{girlId}:{YYYYMMDD}
  clientId String
  girlId   String

  // 缓存内容（流式响应的累积文本）
  content String

  // 用于失效判断的双 hash
  girlDataHash String
  userDataHash String

  // 原始请求参数快照（用于 changeReason 比对）
  prevSnapshot String? // JSON: { emotionalStable, antiFrustrationLevel, signalsLength, pendingActionsLength }

  // daily key（用于按日期清理）
  dailyKey String // YYYYMMDD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([girlId])
  @@index([dailyKey])
  @@map("girl_summary_caches")
}

// ========== 每周复盘报告（M007 S04新增）==========
model WeeklyReview {
  id       String @id @default(uuid())
  clientId String

  // 周期
  weekOf    String // YYYY-MM-DD，周起始日期
  weekStart String // ISO date
  weekEnd   String // ISO date

  // 统计数据
  totalGirls       Int   @default(0)
  newGirlsThisWeek Int   @default(0)
  datesThisWeek    Int   @default(0)
  completedDates   Int   @default(0)
  chatLogsThisWeek Int   @default(0)
  chatLogsLastWeek Int   @default(0)
  chatTrend        Int   @default(0)
  avgTension       Float @default(5.0)

  // 预警统计
  alertTotal   Int @default(0)
  alertP0      Int @default(0)
  alertP1      Int @default(0)
  alertP2      Int @default(0)
  activeAlerts Int @default(0)

  // 阶段变更
  stageChangesTotal Int @default(0)
  stageUpgrades     Int @default(0)
  stageDowngrades   Int @default(0)

  // AI 生成内容（失败的为空/null）
  overallScore       Int?
  overallComment     String?
  strengths          String? // JSON array
  concerns           String? // JSON array
  nextWeekPriorities String? // JSON array
  aiAvailable        Boolean @default(false)

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clientId, weekOf])
  @@index([clientId])
  @@index([weekOf])
  @@map("weekly_reviews")
}

// ========== 反撇分析记录（M007 S03新增）==========
model ReversalAnalysis {
  id       String @id @default(uuid())
  girlId   String
  clientId String

  // AI 分析结果
  isReversal   Boolean @default(false)
  type         String? // 冷淡敷衍型/突然消失型/节奏放慢型/态度模糊型
  confidence   Int     @default(0) // 0-100
  riskLevel    String  @default("none") // high/medium/low/none
  evidence     String? // JSON array
  signals      String? // JSON array
  timeline     String? // JSON array
  suggestion   String?
  differential String?
  rawResponse  String?

  analyzedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([girlId])
  @@index([clientId])
  @@index([riskLevel])
  @@map("reversal_analyses")
}

// ========== AI教练反馈 ==========
model CoachFeedback {
  id       String             @id @default(uuid())
  memoryId String
  memory   ConversationMemory @relation(fields: [memoryId], references: [id])

  // 反馈类型
  type String // 'helpful' | 'not_helpful'

  // 路由相关（用于分析路由准确度）
  routedType  String? // 路由到的类型
  coachesUsed String? // JSON array: 使用的教练ID列表

  // 可选：用户可选填的简短原因
  reason String?

  // 反馈的消息内容（便于回溯）
  messageContent String?

  createdAt DateTime @default(now())

  @@index([memoryId])
  @@index([type])
  @@map("coach_feedbacks")
}

// ========== 客户教练画像（个性化权重）==========
// 每个客户对每个教练在每类问题上有个性化的反馈权重
// 用于：反馈闭环驱动路由个性化
model ClientCoachProfile {
  id           String @id @default(uuid())
  clientId     String
  coachId      String // coach ID e.g. 'tuobuhua', 'tong'
  questionType String // e.g. '关系拉伸', '心态问题', '通用'

  helpfulCount    Int @default(0)
  notHelpfulCount Int @default(0)

  // 动态权重调整量：从反馈历史中学到的 bonus
  // 正数 = 该教练对这类问题对这个客户有加成
  // 负数 = 减益
  feedbackBonus Float @default(0)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([clientId, coachId, questionType])
  @@map("client_coach_profiles")
}

// ========== Guardrail 检查日志 ==========
model GuardrailLog {
  id       String  @id @default(uuid())
  clientId String?
  coachId  String  @default("unified")
  girlId   String?

  checkType String // 'relevance' | 'jailbreak' | 'triage'
  passed    Boolean
  reason    String? // 失败原因
  reasoning String? // LLM 返回的判断理由
  inputText String? // 被检查的输入文本（脱敏后存前100字）

  endpoint String? // 调用的端点，如 '/situation', '/moment', '/agent-chat'
  model    String? // 使用的 guardrail 模型

  // Triage 专用字段（当 checkType='triage' 时使用）
  routeType  String? // 'situation' | 'chat_analysis' | 'reply' | 'moment' | 'overview' | 'optimize_reply' | 'general'
  confidence Float? // 0-1 置信度
  method     String? // 'keyword' | 'llm' | 'coach'

  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([checkType, createdAt])
  @@index([passed, createdAt])
  @@index([endpoint, createdAt])
  @@map("guardrail_logs")
}

// ========== 会员系统 ==========
model Membership {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // 类型：monthly=月度(999元), yearly=年度(8888元)
  type   String @default("monthly")
  // 状态：active/expired/cancelled
  status String @default("active")
  // 实际支付价格（用于对账和记录）
  price  Float  @default(0)

  startDate DateTime
  endDate   DateTime

  // 是否用积分抵扣过（抵扣金额）
  pointsDiscount Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("memberships")
}

// ========== 邀请机制 ==========
model Invitation {
  id        String  @id @default(uuid())
  inviterId String
  inviter   User    @relation("Inviter", fields: [inviterId], references: [id])
  inviteeId String?
  invitee   User?   @relation("Invitee", fields: [inviteeId], references: [id])

  // 8位邀请码
  inviteCode String @unique

  // 是否已激活（被邀请人完成注册并付费后为true）
  activated  Boolean @default(false)
  // 奖励是否已发放（发放500元续费抵扣券）
  rewardPaid Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([inviterId])
  @@index([inviteCode])
  @@map("invitations")
}

// ========== 续费抵扣券 ==========
model RenewalCoupon {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // 面值（元）：目前统一500元
  value Int
  // 类型：invite_reward(邀请奖励)/admin_grant(管理员发放)
  type  String
  // 关联业务ID（如 invitationId）
  refId String?
  note  String?

  // 使用时间（null=未使用）
  usedAt              DateTime?
  // 使用到的会员ID（回填）
  usedForMembershipId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([usedAt])
  @@map("renewal_coupons")
}

// ========== 积分系统 ==========
model PointsLedger {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // 变动数量：正数=增加，负数=减少
  amount       Int
  // 变动后余额
  balanceAfter Int
  // 类型：recharge(充值)/consume(消费)/invite_reward(邀请奖励)/membership_discount(会员抵扣)/admin_adjust(管理员调整)
  type         String
  // 操作人ID（充值/扣减时记录）
  operatorId   String?
  // 关联的业务ID（如 membershipId, invitationId）
  refId        String?
  note         String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("points_ledger")
}

// ========== 学习版块 - 教材章节 ==========
model LearningChapter {
  id         String  @id @default(uuid())
  chapterId  String  @unique // e.g. '01' through '20'
  title      String
  subtitle   String?
  orderIndex Int

  // 章节内容（从教材提取，也可以是Markdown格式的摘要）
  content String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("learning_chapters")
}

// ========== 学习版块 - 用户进度 ==========
model LearningProgress {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  chapterId     String
  // 状态：not_started/in_progress/completed
  status        String    @default("not_started")
  // 完成时间
  completedAt   DateTime?
  // 最后访问时间（用于排序"继续学习"）
  lastVisitedAt DateTime?

  updatedAt DateTime @updatedAt

  @@unique([userId, chapterId])
  @@index([userId])
  @@map("learning_progress")
}

// ========== 截图识别档案（操盘手上传聊天截图，AI提取用户信息）==========
model ScreenshotProfile {
  id         String @id @default(uuid())
  uploadedBy String // operatorId

  // 关联的客户（可能新客户未入库，也可能关联到已有客户）
  clientId String?

  imagePath String

  // AI 提取的信息
  extractedName   String?
  extractedPhone  String?
  extractedAge    String?
  extractedGender String? // 'male'/'female'
  extractedInfo   String? // JSON: 其他提取的字段

  // 状态：pending(待确认)/confirmed(已确认更新)/rejected(已拒绝)
  status String @default("pending")

  // 确认时间
  confirmedAt  DateTime?
  // 确认时关联的用户ID（如果是新建用户）
  linkedUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadedBy])
  @@index([status])
  @@map("screenshot_profiles")
}

// ========== AI 约会方案 ==========
model DatingPlan {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title    String
  scene    String? // 约会场景描述
  content  String? // AI生成的方案内容（Markdown）
  budget   String?
  duration String?

  // 状态：draft/generating/generated/approved
  planStatus String  @default("draft")
  // 生成过程中的讨论记录 [{ role, content, timestamp }]
  discussion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("dating_plans")
}
