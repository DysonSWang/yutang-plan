# 鱼塘计划后端环境配置
PORT=3005

# JWT - 生产环境必须替换为强随机密钥
JWT_SECRET=your-jwt-secret-here

# 智谱AI - 从 https://open.bigmodel.cn/ 获取
ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# 通义千问 - 从 https://dashscope.console.aliyun.com/ 获取
DASH_SCOPE_API_KEY=your-dashscope-api-key-here

# Sentry 错误追踪（可选，https://sentry.io 创建项目后获取）
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
